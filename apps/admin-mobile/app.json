{
  "expo": {
    "name": "FresherFlow Admin",
    "slug": "fresherflow-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fresherflow-admin",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020404"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.fresherflow.admin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020404"
      },
      "package": "in.fresherflow.admin",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-secure-store",
      "expo-updates"
    ],
    "extra": {
      "apiUrl": "https://api.fresherflow.in",
      "eas": {
        "projectId": "fresherflow-admin-mobile"
      }
    }
  }
}