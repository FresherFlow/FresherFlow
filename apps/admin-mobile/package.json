{
  "name": "admin-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"App.tsx\" \"index.ts\" --cache",
    "typecheck": "tsc --noEmit",
    "start": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --port 0",
    "start:offline": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --offline --port 0",
    "android": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --android --port 0",
    "android:offline": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --android --offline --port 0",
    "ios": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --ios --port 0",
    "ios:offline": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --ios --offline --port 0",
    "web": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --web --port 0"
  },
  "dependencies": {
    "@fresherflow/api-client": "*",
    "@repo/frontend-core": "*",
    "@repo/ui": "*",
    "@fresherflow/constants": "*",
    "@fresherflow/schemas": "*",
    "@fresherflow/types": "*",
    "@fresherflow/utils": "*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "expo": "~54.0.33",
    "expo-linear-gradient": "^15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.12",
    "lucide-react-native": "^0.564.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.1",
    "react-native-passkey": "^3.3.2",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-wheel-color-picker": "^1.3.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-universe": "^15.0.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
