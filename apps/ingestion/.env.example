# =============================================
# Ingestion Service — Environment Variables
# =============================================
# Copy this to .env and fill in your values.

# --- Redis (for BullMQ queue + dedupe hashing) ---
REDIS_URL="redis://default:password@host:port"

# --- Database (only needed if writing directly, usually done via worker) ---
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"

# --- App ---
NODE_ENV="production"
PORT=3005

# --- Scheduler ---
# How often the cron fetches from ATS sources (cron expression)
INGESTION_CRON_SCHEDULE="*/20 * * * *"
INGESTION_CRON_ENABLED=true

# --- Scoring thresholds ---
INGESTION_FRESHER_SCORE_MIN=35
INGESTION_HIGH_CONFIDENCE_SCORE=55

# --- Staging DB (for seedLeverSources script, not needed in production) ---
# STAGING_DATABASE_URL="postgresql://..."
