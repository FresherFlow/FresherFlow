# Database
DATABASE_URL="postgresql://user:password@localhost:5432/job_platform?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/job_platform?schema=public"
# Supabase — staging DB for ingestion pipeline (keeps Neon compute hours reserved for users)
STAGING_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.gdridbxhoqfztcuyzzja.supabase.co:5432/postgres"

# JWT Secrets (Change these in production!)
JWT_ACCESS_SECRET="your-super-secret-access-key-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-minimum-32-characters-long"
ADMIN_ACCESS_TOKEN_EXPIRY="7d"
ADMIN_ACCESS_COOKIE_DAYS="7"

# Frontend URL (used for CORS)
FRONTEND_URL="http://localhost:3000"
FRONTEND_URLS="http://localhost:3000"
# Allow https://*.fresherflow.in automatically in production CORS checks
CORS_ALLOW_FRESHERFLOW_SUBDOMAINS="true"
# Optional cookie domain for cross-subdomain auth in production
# Example: COOKIE_DOMAIN=".fresherflow.in"
COOKIE_DOMAIN=""
REDIS_URL=""

# Environment
NODE_ENV="development"
APP_MODE="all" # all | user | admin
# Public feed teaser cap for unauthenticated users
# Full feed requires login; guests see first N items only.
GUEST_FEED_LIMIT="12"

# Optional: Sentry for error tracking
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Email delivery (Resend)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
# Use your verified domain sender in production
# EMAIL_FROM="FresherFlow <no-reply@fresherflow.in>"
# Optional: separate sender for alert campaigns
# ALERTS_EMAIL_FROM="FresherFlow Alerts <alerts@fresherflow.in>"
# Emergency kill switch for alert emails (digest/closing soon/new job)
# ALERT_EMAILS_ENABLED="false"

# Telegram Bot Configuration (Optional)
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
# TELEGRAM_ADMIN_CHAT_ID="-1001234567890"
# TELEGRAM_PUBLIC_CHANNEL="@fresherflow_jobs"  # Optional: For broadcasting to public

# Web Push (Required for browser push notifications)
# Generate once: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:support@fresherflow.in"

# Cron auth (required for GitHub Actions cron endpoints)
# CRON_SECRET="set-a-long-random-secret"

# Internal API URL used by the worker to dispatch cron tasks via HTTP
# Must match the API deployment URL (no trailing slash)
# Example for Railway: INTERNAL_API_URL="https://api-production.up.railway.app"
# Example for local dev: INTERNAL_API_URL="http://localhost:4000"
# INTERNAL_API_URL=""


# Link verification bot cron (optional)
# VERIFICATION_CRON_ENABLED="true"
# VERIFICATION_CRON_SCHEDULE="0 */6 * * *"

# Expiry cron (optional)
# Marks jobs/walk-ins expired once per day at local midnight.
# EXPIRY_CRON_SCHEDULE="0 0 * * *"
# EXPIRY_CRON_TIMEZONE="Asia/Kolkata"

# Alerts cron (optional)
# Runs personalized email digest + closing soon alerts
# ALERTS_CRON_ENABLED="true"
# ALERTS_CRON_SCHEDULE="*/30 * * * *"

# Ingestion worker/cron (optional)
# Keep disabled on API service and enable on dedicated worker service.
# INGESTION_CRON_ENABLED="false"
# INGESTION_CRON_SCHEDULE="*/20 * * * *"
# INGESTION_DEFAULT_ADMIN_ID="<admin-user-id-for-draft-posting>"
# INGESTION_FRESHER_SCORE_MIN="35"
# INGESTION_HIGH_CONFIDENCE_SCORE="55"
# INGESTION_WORKER_TOKEN="set-a-long-random-token-for-cloudflare-email-worker"
# INTERNAL_TRACKING_EMAILS="admin@fresherflow.in,test@fresherflow.in"
# Safety: keep ingestion API disabled in production until pipeline is finalized.
# Set true only when ingestion is production-ready.
# INGESTION_ENABLE_IN_PROD="false"
