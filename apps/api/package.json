{
    "name": "fresherflow-api",
    "version": "1.0.0",
    "description": "Production-grade backend for Job & Walk-in Opportunity Platform",
    "main": "dist/index.js",
    "scripts": {
        "prune:api": "turbo prune fresherflow-api --docker",
        "dev": "nodemon --exec \"ts-node\" src/index.ts",
        "dev:worker": "nodemon --exec \"ts-node\" src/worker.ts",
        "build": "pnpm run build:deps && tsc && node ../../scripts/copy-parser-runtime.mjs",
        "build:deps": "pnpm --filter @fresherflow/types build && pnpm --filter @fresherflow/constants build && pnpm --filter @fresherflow/logger build && pnpm --filter @fresherflow/config build && pnpm --filter @fresherflow/utils build && pnpm --filter @fresherflow/schemas build && pnpm --filter @fresherflow/database build && pnpm --filter @fresherflow/search build && pnpm --filter @fresherflow/domain build && pnpm --filter @fresherflow/parser build",
        "start": "node dist/index.js",
        "start:worker": "node dist/worker.js",
        "db:push": "prisma db push --schema=../../packages/database/prisma/schema.prisma",
        "db:studio": "prisma studio --schema=../../packages/database/prisma/schema.prisma",
        "db:generate": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
        "prisma:migrate": "prisma migrate resolve --rolled-back 20260518130000_sync_core_auth_schema --schema=../../packages/database/prisma/schema.prisma || true && prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "build:api": "pnpm run build",
        "start:api": "pnpm run start",
        "lint": "eslint \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "jobs",
        "walk-ins",
        "opportunities"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1049.0",
        "@bull-board/api": "^6.20.5",
        "@bull-board/express": "^6.20.5",
        "@fresherflow/auth": "*",
        "@fresherflow/config": "*",
        "@fresherflow/constants": "*",
        "@fresherflow/database": "*",
        "@fresherflow/domain": "*",
        "@fresherflow/logger": "*",
        "@fresherflow/parser": "*",
        "@fresherflow/queue": "*",
        "@fresherflow/redis": "*",
        "@fresherflow/schemas": "*",
        "@fresherflow/search": "*",
        "@fresherflow/types": "*",
        "@fresherflow/utils": "*",
        "@prisma/client": "^6.2.0",
        "@sentry/node": "^10.38.0",
        "@simplewebauthn/server": "^13.2.2",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.10",
        "@types/node": "^22.10.5",
        "@types/node-cron": "^3.0.11",
        "axios": "^1.13.4",
        "bcrypt": "^5.1.1",
        "chalk": "^4.1.2",
        "compromise": "^14.14.5",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "country-state-city": "^3.2.1",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "express-validator": "^7.3.2",
        "firebase-admin": "^13.10.0",
        "fuse.js": "^7.1.0",
        "google-auth-library": "^10.5.0",
        "helmet": "^8.0.0",
        "ioredis": "^5.5.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.1",
        "natural": "^8.1.0",
        "node-cron": "^3.0.3",
        "otplib": "^13.2.1",
        "qrcode": "^1.5.4",
        "resend": "^6.9.1",
        "twitter-api-v2": "^1.29.0",
        "web-push": "^3.6.7",
        "winston": "^3.19.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/qrcode": "^1.5.6",
        "@types/supertest": "^6.0.2",
        "@types/web-push": "^3.6.4",
        "@vitest/ui": "^4.0.18",
        "eslint": "^9.10.0",
        "eslint-config-prettier": "^9.1.0",
        "nodemon": "^3.1.9",
        "prisma": "^6.2.0",
        "supertest": "^7.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.5.0",
        "vitest": "^4.0.18"
    }
}
