{
  "expo": {
    "name": "FresherFlow",
    "slug": "fresherflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fresherflow",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.fresherflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "in.fresherflow.app",
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#00000000",
        "translucent": true
      },
      "navigationBar": {
        "barStyle": "light-content",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "https://api.fresherflow.in",
      "eas": {
        "projectId": "73c68383-7b6a-4934-8b65-e97517c5b161"
      }
    }
  }
}
