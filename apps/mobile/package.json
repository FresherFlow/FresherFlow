{
  "name": "mobile",
  "version": "1.2.0",
  "main": "index.js",
  "scripts": {
    "start": "cross-env MAX_WAIT_TIME=800000 APP_ENV=development EXPO_NO_DOCTOR=1 EXPO_NO_TELEMETRY=1 node ../../node_modules/expo/bin/cli start",
    "start:dev": "cross-env MAX_WAIT_TIME=800000 APP_ENV=development node ../../node_modules/expo/bin/cli start -c --dev-client",
    "start:staging": "cross-env MAX_WAIT_TIME=800000 APP_ENV=staging node ../../node_modules/expo/bin/cli start -c --dev-client",
    "android": "node scripts/android-env.js development run",
    "android:dev": "node scripts/android-env.js development run",
    "android:staging": "node scripts/android-env.js staging run",
    "android:production": "node scripts/android-env.js production run",
    "native:dev": "node scripts/android-env.js development prebuild",
    "native:staging": "node scripts/android-env.js staging prebuild",
    "native:production": "node scripts/android-env.js production prebuild",
    "gradle:assemble:dev": "node scripts/android-env.js development assemble",
    "gradle:assemble:staging": "node scripts/android-env.js staging assemble",
    "gradle:assemble:production": "node scripts/android-env.js production assemble",
    "eas:build:dev": "pnpm dlx eas-cli build --platform android --profile development",
    "eas:build:staging": "pnpm dlx eas-cli build --platform android --profile staging",
    "eas:build:production": "pnpm dlx eas-cli build --platform android --profile production",
    "apk:staging": "pnpm eas:build:staging",
    "apk:production": "pnpm eas:build:production",
    "ios": "cross-env MAX_WAIT_TIME=800000 APP_ENV=development node ../../node_modules/expo/bin/cli run:ios",
    "ios:staging": "cross-env MAX_WAIT_TIME=800000 APP_ENV=staging node ../../node_modules/expo/bin/cli run:ios",
    "ios:prod": "cross-env MAX_WAIT_TIME=800000 APP_ENV=production node ../../node_modules/expo/bin/cli run:ios",
    "web": "node ../../node_modules/expo/bin/cli start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@fresherflow/api-client": "*",
    "@fresherflow/constants": "*",
    "@fresherflow/domain": "*",
    "@fresherflow/types": "*",
    "@fresherflow/utils": "*",
    "@gorhom/bottom-sheet": "^5.2.14",
