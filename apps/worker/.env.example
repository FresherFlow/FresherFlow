# =============================================
# Worker Service — Environment Variables
# =============================================
# Copy this to .env and fill in your values.

# --- Database (Neon) ---
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# --- Redis (BullMQ queue backing) ---
REDIS_URL="redis://default:password@host:port"
REDIS_ENABLED=true

# --- JWT ---
JWT_ACCESS_SECRET="min-32-char-random-secret"
JWT_REFRESH_SECRET="min-32-char-random-secret"
ACCESS_TOKEN_EXPIRY="24h"
REFRESH_TOKEN_EXPIRY="30d"

# --- App ---
NODE_ENV="production"
PORT=5001

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
ADMIN_EMAIL="admin@yourdomain.com"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxx"

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1"
TELEGRAM_ADMIN_CHAT_ID="your-chat-id"
TELEGRAM_PUBLIC_CHANNEL="@yourchannel"
TELEGRAM_ERROR_COOLDOWN_MINUTES=5
TELEGRAM_ALLOW_DEV=false

# --- Web Push (VAPID) ---
# Generate: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:support@yourdomain.com"

# --- Infrastructure Gating (Lean Mode) ---
ENABLE_CRON_TASKS="false"
ENABLE_HEALTH_CHECK="true"
ENABLE_EMAIL_SENDING="true"
ENABLE_TELEGRAM_BROADCAST="false"
ENABLE_SOCIAL_POSTING="false"
ENABLE_PUSH_NOTIFICATIONS="false"
ENABLE_INGESTION="false"
ENABLE_LINK_VERIFICATION="false"

# --- Maintenance Thresholds (Days/Hours) ---
STALE_LISTING_DAYS="30"
PRUNE_RAW_OPPORTUNITY_DAYS="14"
PRUNE_LOGS_DAYS="30"
CLOSING_SOON_WINDOW_HOURS="48"
USERNAME_COOLDOWN_DAYS="30"

# --- Ingestion Config ---
INGESTION_DEFAULT_ADMIN_ID="your-admin-user-uuid"
INGESTION_FRESHER_SCORE_MIN=35
INGESTION_HIGH_CONFIDENCE_SCORE=55
