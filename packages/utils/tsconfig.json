{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@fresherflow/parser": ["../parser/dist/index"],
            "@fresherflow/domain": ["../domain/dist/index"],
            "@fresherflow/types": ["../types/dist/index"]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "**/*.test.ts"
    ]
}
