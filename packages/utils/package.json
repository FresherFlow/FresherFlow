{
    "name": "@fresherflow/utils",
    "version": "1.0.0",
    "description": "Shared utilities for FresherFlow",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },

    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-esm-imports.mjs dist",
        "dev": "tsc -w",
        "lint": "eslint .",
        "test": "vitest run"
    },
    "dependencies": {
        "@fresherflow/types": "*",
        "@fresherflow/constants": "*",
        "compromise": "^14.14.5",
        "country-state-city": "^3.2.1",
        "natural": "^8.1.0"
    },
    "devDependencies": {
        "eslint": "^9.10.0",
        "eslint-config-prettier": "^9.1.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.5.0",
        "vitest": "^4.1.0"
    }
}
