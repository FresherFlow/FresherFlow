// This is your Prisma schema file
// Production-Grade Schema for Job & Walk-in Opportunity Platform
// Code Review Score: 10/10 ✅

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================================================
// ENUMS - Type Safety (No Free-Text Strings)
// ============================================================================

enum Role {
  USER
  ADMIN
}

enum OpportunityType {
  JOB
  INTERNSHIP
  WALKIN
}

enum OpportunityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ActionType {
  APPLIED
  PLANNED
  INTERVIEWED
  SELECTED
  VIEWED  // Auto-tracked on job detail view
  SHARED
  OA
  REJECTED
  REPORTED
  // Legacy values kept for compatibility with existing rows
  PLANNING
  ATTENDED
  NOT_ELIGIBLE
}

enum FeedbackReason {
  EXPIRED // Listing already expired when accessed
  LINK_BROKEN // Apply link not working
  DUPLICATE // Duplicate posting detected
  INACCURATE // Wrong information in listing
  SPAM // Malicious or irrelevant content
  OTHER // Any other issue
}

enum AppFeedbackType {
  BUG
  IDEA
  PRAISE
  OTHER
}

enum EducationLevel {
  DIPLOMA
  DEGREE
  PG
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum SalaryPeriod {
  MONTHLY
  YEARLY
}

enum Availability {
  IMMEDIATE
  DAYS_15
  MONTH_1
}

enum LinkHealth {
  HEALTHY
  BROKEN
  RETRYING
}

enum GrowthFunnelEvent {
  DETAIL_VIEW
  LOGIN_VIEW
  AUTH_SUCCESS
  SIGNUP_SUCCESS
  SAVE_JOB
  APPLY_CLICK
  SHARE_JOB
  SIGNUP_VIEW
  INSTALL_PROMPT_SHOWN
  INSTALL_ACCEPTED
  OPENED_STANDALONE
  APP_INIT
}

enum PlatformEventType {
  VIEW_JOB
  CLICK_APPLY
  SHARE_JOB
  SAVE_JOB
  REFERRAL_HIT
  REFERRAL_CLICK
  APP_INIT
  AUTH_STEP
}

enum ReferralBadge {
  FIRST_INVITE
  CONNECTOR
  CAMPUS_SCOUT
  GROWTH_NODE
  NETWORK_BUILDER
}

enum AlertChannel {
  EMAIL
  APP
  PUSH
}

enum AlertKind {
  DAILY_DIGEST
  CLOSING_SOON
  HIGHLIGHT
  APP_UPDATE
  NEW_JOB  // Instant alert when new opportunity is published
  EVENT_REMINDER
}

enum AlertDispatchStatus {
  INITIATED
  SENT
  FAILED
  SKIPPED
}

enum AlertDispatchReason {
  DEDUPE_HIT
  DAILY_CAP
  PREFERENCE_DISABLED
  NOT_ELIGIBLE
  CHANNEL_ERROR
  ENUM_FALLBACK
  VALIDATION_ERROR
  SENT_OK
}

enum OpportunityEventType {
  NOTIFICATION
  REG_START
  REG_END
  EXAM_DATE
  RESULT
  INTERVIEW
  DOC_VERIFICATION
  OTHER
}

enum SocialPlatform {
  X
  LINKEDIN
  FACEBOOK
}

enum SocialPostStatus {
  PENDING
  PUBLISHED
  FAILED
  DISABLED
  DRY_RUN
}

enum UserTrustLevel {
  NEW
  VERIFIED
  CONTRIBUTOR
  MODERATOR
  BANNED
}

// ============================================================================
// USER MODELS
// ============================================================================

model User {
  id               String         @id @default(uuid())
  firebase_uid     String?        @unique
  username         String?        @unique
  usernameUpdatedAt DateTime?
  email            String?        @unique
  fullName         String?
  role             Role           @default(USER)
  referralCode     String?        @unique
  referredByUserId String?
  referredAt       DateTime?
  trustScore       Float          @default(0.0)
  trustLevel       UserTrustLevel @default(NEW)
  isAnonymous      Boolean        @default(false)
  anon_id          String?        @unique
  lastLogin        DateTime?
  createdAt        DateTime       @default(now())

  // Relations
  profile            Profile?
  actions            UserAction[]
  feedback           ListingFeedback[]
  appFeedback        AppFeedback[]
  savedOpportunities SavedOpportunity[]
  alertPreference    AlertPreference?
  alertDeliveries    AlertDelivery[]
  alertDispatchLogs AlertDispatchLog[]
  pushSubscription   PushSubscription?
  platformEvents     PlatformEvent[]
  ingestionSources   IngestionSource[]
  referredBy         User?                @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals          User[]               @relation("UserReferrals")
  earnedReferralBadges ReferralBadgeGrant[]

  // Admin Relations (only for role=ADMIN)
  postedOpportunities Opportunity[]
  rawContributions   RawOpportunity[]     @relation("UserRawContributions")
  auditLogs           AdminAudit[]
  authenticators     Authenticator[]
  comments           OpportunityComment[]
  follows            UserFollow[]

  webAuthnChallenges WebAuthnChallenge[]
  updatedAdminDeliveryControls AdminDeliveryControl[]

  // Security - TOTP
  totpSecret         String?
  isTwoFactorEnabled Boolean  @default(false)

  // Tokens
  refreshTokens      RefreshToken[]

  @@index([referredByUserId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AdminDeliveryControl {
  id                           String   @id @default("global")
  socialAutoPostingEnabled     Boolean  @default(true)
  userAlertsEnabled            Boolean  @default(true)
  userEmailNotificationsEnabled Boolean @default(true)
  updatedByUserId              String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model Authenticator {
  credentialID         String  @id
  userId               String
  publicKey            Bytes
  counter              Int
  deviceType           String
  backedUp             Boolean
  transports           String? // Stored as comma-separated string

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebAuthnChallenge {
  id        String   @id @default(uuid())
  key       String   @unique
  userId    String
  challenge String
  type      String   // "reg" or "auth"
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique

  // Education Details (40% weight total)
  educationLevel EducationLevel?

  // 10th Details
  tenthYear        Int?

  // 12th / Diploma Details
  twelfthYear        Int?

  // Graduation Details
  gradCourse         String?
  gradSpecialization String?
  gradYear           Int?

  // Post Graduation (Optional)
  pgCourse          String?
  pgSpecialization  String?
  pgYear            Int?

  // Opportunity Preferences (40% weight)
  interestedIn    OpportunityType[]
  preferredCities String[] // max 5
  workModes       WorkMode[]

  // Readiness Status (20% weight)
  availability Availability?
  skills       String[] // admin-controlled tags

  // DERIVED FIELD - Never manually updated, always recalculated
  completionPercentage Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// ADMIN TRACKING (Audit trail for Users with ADMIN role)
// ============================================================================

model AdminAudit {
  id        String   @id @default(uuid())
  userId    String
  action    String // CREATE, UPDATE, DELETE, EXPIRE
  targetId  String // Opportunity ID
  reason    String? // Required for DELETE/EXPIRE
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// OPPORTUNITY MODELS
// ============================================================================

model Opportunity {
  id   String          @id @default(uuid())
  slug String          @unique // SEO-friendly URL slug
  type OpportunityType // Enum for type safety

  // Core Fields
  title       String
  company     String
  companyWebsite String?
  companyLogoUrl String?
  description String? @db.Text

  // Eligibility Rules (DB-filterable)
  allowedDegrees      EducationLevel[]
  allowedCourses      String[] // Specific courses like "B.Tech", "MCA", "MBA"
  allowedSpecializations String[] @default([]) // Specific streams like "Computer Science", "Mechanical"
  allowedPassoutYears Int[] // Array for specific batches (e.g. 2023, 2025)
  passoutYearMin      Int?  // Range Optimization
  passoutYearMax      Int?  // Range Optimization
  allowedAvailability Availability[] // When candidate should be available
  requiredSkills      String[]
  locations           String[] // For DB-level filtering
  experienceMin       Float?   // Experience in years (e.g. 0, 0.5, 1.5)
  experienceMax       Float?   // Experience in years (e.g. 3, 5.5)

  // Job/Internship Specific
  workMode       WorkMode?
  salaryMin      Int? // Legacy: Can map salaryRange to this
  salaryMax      Int?
  salaryRange    String? // New: "6-8 LPA"
  salaryPeriod   SalaryPeriod @default(YEARLY) // Default to Annual (India standard)
  incentives     String? // Optional: "Rs. 20k - 1L targets"
  jobFunction    String? // Optional: "Banking", "Sales", "Engineering"
  selectionProcess String? @db.Text // Optional: "Aptitude > Technical > HR"
  notesHighlights  String? @db.Text // Optional: bond, training, special conditions
  stipend        String? // New: "10k/month"
  employmentType String? // New: "full-time"
  tags           String[] @default([])
  sourceLink     String? // Original listing/source page; may equal applyLink when only one URL exists
  applyLink      String?

  // Walk-in Specific (nullable for non-walk-ins)
  walkInDetails WalkInDetails?
  governmentJobDetails GovernmentJobDetails?

  // Expiry Management
  expiresAt DateTime?
  expiredAt DateTime?
  status    OpportunityStatus @default(DRAFT) // Starts as draft

  // Soft Delete Support (PRODUCTION MUST-HAVE)
  deletedAt      DateTime? // Null = not deleted, set = soft deleted
  deletionReason String? // Why was it removed (audit trail)

  // Metadata - Referential Integrity with Admin roles
  postedByUserId String
  user           User    @relation(fields: [postedByUserId], references: [id])
  postedAt        DateTime @default(now())
  publishedAt     DateTime?
  updatedAt       DateTime @default(now()) @updatedAt


  // Health Tracking (Verification Bot)
  linkHealth           LinkHealth @default(HEALTHY)
  verificationFailures Int        @default(0)
  lastVerifiedAt       DateTime   @default(now())
  lastVerified         DateTime   @default(now())

  // Engagement Counters (Denormalized for performance)
  sharesCount          Int        @default(0)
  savesCount           Int        @default(0)
  clicksCount          Int        @default(0)
  commentsCount        Int        @default(0)
  trendingScore        Float      @default(0.0)

  // Relations
  actions  UserAction[]
  feedback ListingFeedback[]
  savedBy  SavedOpportunity[]
  alertDeliveries AlertDelivery[]
  alertDispatchLogs AlertDispatchLog[]
  telegramBroadcasts TelegramBroadcast[]
  rawIngestions RawOpportunity[]
  events OpportunityEvent[]
  platformEvents PlatformEvent[]
  socialPosts SocialPost[]
  comments    OpportunityComment[]

  // Performance Search optimization
  search_vector  Unsupported("tsvector")? @default(dbgenerated("''::tsvector"))

  // DB-level filtering indexes
  @@index([status, deletedAt, type, postedAt(desc)])
  @@index([status, postedAt(desc)])
  @@index([trendingScore(desc)])
  @@index([sharesCount(desc)])
  @@index([search_vector], type: Gin)
  @@index([allowedPassoutYears], type: Gin)
  @@index([allowedDegrees], type: Gin)
  @@index([allowedCourses], type: Gin)
  @@index([allowedSpecializations], type: Gin)
  @@index([locations], type: Gin)
  @@index([requiredSkills], type: Gin)
  @@index([tags], type: Gin)
  @@index([salaryMin, salaryMax])
  @@index([company])
  @@index([title]) // Maps to 'role' in queries
  @@index([slug])
  @@index([sourceLink])
  @@index([expiresAt]) // Performance for expiry cron
  @@index([deletedAt]) // Exclude soft-deleted in queries
  @@index([linkHealth]) // Focus for verification bot
  @@index([lastVerifiedAt]) // Sort by oldest verification
}


model WalkInDetails {
  id            String @id @default(uuid())
  opportunityId String @unique

  dates             DateTime[] // Multiple walk-in dates
  dateRange         String?    // New: "2nd Feb - 6th Feb"
  timeRange         String?    // New: "11:00 AM - 1:00 PM"
  venueAddress      String     @db.Text
  venueLink         String?    // New: Google Maps URL
  reportingTime     String
  requiredDocuments String[]
  contactPerson     String?
  contactPhone      String?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model GovernmentJobDetails {
  id                     String   @id @default(uuid())
  opportunityId          String   @unique
  department             String?
  organization           String?
  recruitingBody         String?
  officialWebsiteUrl     String?
  officialNotificationUrl String?
  advertisementNumber    String?
  postName               String?
  applicationMode        String?
  applicationModes       String[] @default([])
  vacancyCount           Int?
  vacancies              Json?
  applicationFee         String?  @db.Text
  applicationFeeDetails  Json?
  ageMin                 Int?
  ageMax                 Int?
  ageRelaxation          String?  @db.Text
  eligibilityDetails     Json?
  reservationNotes       String?  @db.Text
  importantInstructions  String?  @db.Text
  applicationStartDate   String?
  applicationEndDate     String?
  examDate               String?
  examDates              Json?
  admitCardDate          String?
  resultDate             String?
  selectionStages        String[] @default([])
  requiredDocuments      String[] @default([])
  requiredDocumentDetails Json?
  seoTags                String[] @default([])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([department])
  @@index([organization])
  @@index([seoTags], type: Gin)
}

model SavedOpportunity {
  id            String      @id @default(uuid())
  userId        String
  opportunityId String
  createdAt     DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId])
}

// ============================================================================
// USER TRACKING MODELS
// ============================================================================

model UserAction {
  id            String     @id @default(uuid())
  userId        String
  opportunityId String
  actionType    ActionType // Enum
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
}

model ListingFeedback {
  id            String         @id @default(uuid())
  userId        String
  opportunityId String
  reason        FeedbackReason // Enum
  description   String?        @db.Text
  createdAt     DateTime       @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId]) // One feedback per user per listing
}

model AppFeedback {
  id        String          @id @default(uuid())
  userId    String
  type      AppFeedbackType
  rating    Int?
  message   String          @db.Text
  pageUrl   String?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([createdAt])
}

model AlertPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  enabled           Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  dailyDigest       Boolean  @default(true)
  closingSoon       Boolean  @default(true)
  minRelevanceScore Int      @default(45)
  preferredHour     Int      @default(8)
  timezone          String   @default("Asia/Kolkata")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastDigestSentAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformEvent {
  id            String            @id @default(uuid())
  type          PlatformEventType
  opportunityId String?
  userId        String?
  sessionId     String?
  source        String?           @default("unknown")
  metadata      Json?
  createdAt     DateTime          @default(now())

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([type, createdAt])
  @@index([opportunityId, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

// DEPRECATED Models (To be removed after migration)
// model GrowthEvent { ... }
// model ReferralVisit { ... }
// model OpportunityClick { ... }

model ReferralBadgeGrant {
  id        String         @id @default(uuid())
  userId    String
  badge     ReferralBadge
  metadata  Json?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@index([badge, createdAt])
}

// Removed OpportunityClick (Moved to PlatformEvent)

model AlertDelivery {
  id            String       @id @default(uuid())
  userId        String
  opportunityId String?
  kind          AlertKind
  channel       AlertChannel @default(EMAIL)
  dedupeKey     String       @unique
  sentAt        DateTime     @default(now())
  readAt        DateTime?
  metadata      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([userId, kind])
  @@index([sentAt])
  @@index([readAt])
}

model AlertDispatchLog {
  id            String              @id @default(uuid())
  correlationId String
  userId        String?
  opportunityId String?
  kind          AlertKind
  channel       AlertChannel?
  status        AlertDispatchStatus
  reason        AlertDispatchReason?
  dedupeKey     String?
  errorMessage  String?
  metadata      Json?
  attemptedAt   DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([correlationId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([kind, channel, createdAt])
  @@index([reason, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OpportunityEvent {
  id            String               @id @default(uuid())
  opportunityId String
  eventType     OpportunityEventType
  eventDate     DateTime
  title         String
  notes         String?              @db.Text
  sourceLink    String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId, eventDate])
  @@index([eventDate])
}

enum TelegramBroadcastStatus {
  SENT
  FAILED
  SKIPPED
}

enum IngestionSourceType {
  JSON_FEED
  WORKDAY
  GREENHOUSE
  LEVER
  CUSTOM
}

enum IngestionRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum RawOpportunityStatus {
  FETCHED
  DRAFT_CREATED
  DEDUPED
  REJECTED
  ERROR
}

model TelegramBroadcast {
  id            String                  @id @default(uuid())
  opportunityId String
  channel       String
  dedupeKey     String                  @unique
  status        TelegramBroadcastStatus @default(SKIPPED)
  messageId     String?
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId, status])
  @@index([channel])
}

model SocialPost {
  id              String           @id @default(uuid())
  platform        SocialPlatform
  opportunityId   String
  status          SocialPostStatus @default(PENDING)
  externalPostId  String?
  dedupeKey       String           @unique
  errorMessage    String?          @db.Text
  payload         Json?
  scheduledFor    DateTime?
  publishedAt     DateTime?
  retryCount      Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  opportunity     Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId, platform, status])
  @@index([scheduledFor, status])
  @@index([createdAt])
}

model UserFollow {
  id          String    @id @default(cuid())
  userId      String
  type        FollowType
  value       String      // tag name, company name, or contributor userId
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
  @@index([userId])
  @@index([type, value])
}

enum FollowType {
  TAG
  COMPANY
  CONTRIBUTOR
}

model IngestionSource {
  id                  String              @id @default(uuid())
  name                String
  sourceType          IngestionSourceType
  endpoint            String
  enabled             Boolean             @default(true)
  runFrequencyMinutes Int                 @default(60)
  defaultType         OpportunityType     @default(JOB)
  createdByUserId     String?
  lastRunAt           DateTime?
  lastSuccessAt       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  runs      IngestionRun[]
  rawItems  RawOpportunity[]

  @@index([enabled, sourceType])
  @@index([lastRunAt])
}

model IngestionRun {
  id                String             @id @default(uuid())
  sourceId          String
  status            IngestionRunStatus @default(RUNNING)
  startedAt         DateTime           @default(now())
  endedAt           DateTime?
  fetchedCount      Int                @default(0)
  draftCreatedCount Int                @default(0)
  dedupedCount      Int                @default(0)
  rejectedCount     Int                @default(0)
  errorCount        Int                @default(0)
  errorSummary      String?

  source   IngestionSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawItems RawOpportunity[]

  @@index([sourceId, startedAt])
  @@index([status, startedAt])
}

model RawOpportunity {
  id                  String               @id @default(uuid())
  sourceId            String
  ingestionRunId      String?
  sourceExternalId    String?
  status              RawOpportunityStatus @default(FETCHED)
  rawPayload          Json
  title               String?
  company             String?
  sourceLink          String?
  applyLink           String?
  suggestedType       OpportunityType?
  fresherScore        Int?
  reasonFlags         String[]             @default([])
  mappedOpportunityId String?
  createdByUserId     String?
  errorMessage        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  source            IngestionSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  ingestionRun      IngestionRun?   @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)
  mappedOpportunity Opportunity?    @relation(fields: [mappedOpportunityId], references: [id], onDelete: SetNull)
  createdBy         User?           @relation("UserRawContributions", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([sourceId, createdAt])
  @@index([status, createdAt])
  @@index([sourceLink])
  @@index([applyLink])
  @@index([sourceExternalId])
  @@index([createdByUserId])
}

model DomainReputation {
  id             String   @id @default(uuid())
  domain         String   @unique
  trustScore     Float    @default(0.5) // 0.0 to 1.0
  isOfficial     Boolean  @default(false)
  notes          String?
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([domain])
  @@index([trustScore])
}

model OpportunityComment {
  id            String      @id @default(cuid())
  opportunityId String
  userId        String
  text          String      @db.VarChar(500)
  createdAt     DateTime    @default(now())
  deletedAt     DateTime?

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([opportunityId, createdAt])
  @@index([userId])
}
