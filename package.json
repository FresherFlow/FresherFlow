{
  "name": "fresherflow",
  "version": "1.0.0",
  "description": "Job & Walk-in Opportunity Platform - Proper Monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/*",
    "firebase/functions"
  ],
  "scripts": {
    "postinstall": "pnpm exec prisma generate --schema=packages/database/prisma/schema.prisma",
    "prune:api": "turbo prune fresherflow-api --docker",
    "prune:web": "turbo prune fresherflow-web --docker",
    "kill:port": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 5000 -EA SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { taskkill /F /PID $p } else { Write-Host 'Port 5000 is free' }\"",
    "kill:web-port": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 3000 -EA SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { taskkill /F /PID $p } else { Write-Host 'Port 3000 is free' }\"",
    "kill:worker-port": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 5001 -EA SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { taskkill /F /PID $p } else { Write-Host 'Port 5001 is free' }\"",
    "kill:admin-mobile-port": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 8082 -EA SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { taskkill /F /PID $p } else { Write-Host 'Port 8082 is free' }\"",
    "kill:mobile-port": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 8081 -EA SilentlyContinue).OwningProcess | Select-Object -First 1; if ($p) { taskkill /F /PID $p } else { Write-Host 'Port 8081 is free' }\"",
    "kill:ports": "pnpm kill:web-port && pnpm kill:port && pnpm kill:worker-port && pnpm kill:admin-mobile-port && pnpm kill:mobile-port",
    "dev": "pnpm kill:ports && turbo run dev --concurrency=20",
    "dev:stack": "concurrently -k -n API,WEB -c green,cyan \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:start": "pnpm kill:ports && concurrently -k -n API,WEB,WORKER -c green,cyan,yellow \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm --filter ./apps/worker dev\"",
    "dev:check": "node scripts/check-local-dev.js",
    "dev:api": "pnpm --filter ./apps/api dev",
    "dev:worker": "pnpm --filter ./apps/worker dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:admin-mobile": "pnpm --filter ./apps/admin-mobile start",
    "dev:mobile": "pnpm --filter ./apps/mobile start",
    "android:admin-mobile": "pnpm --filter ./apps/admin-mobile android",
    "android:admin-mobile:offline": "pnpm --filter ./apps/admin-mobile android:offline",
    "android:dev": "pnpm android:mobile",
    "android:mobile": "pnpm --filter ./apps/mobile android",
    "android:staging": "pnpm --filter ./apps/mobile android:staging",
    "android:production": "pnpm --filter ./apps/mobile android:production",
    "gradle:assemble:dev": "pnpm --filter ./apps/mobile gradle:assemble:dev",
    "gradle:assemble:staging": "pnpm --filter ./apps/mobile gradle:assemble:staging",
    "gradle:assemble:production": "pnpm --filter ./apps/mobile gradle:assemble:production",
    "eas:build:dev": "pnpm --filter ./apps/mobile eas:build:dev",
    "eas:build:staging": "pnpm --filter ./apps/mobile eas:build:staging",
    "eas:build:production": "pnpm --filter ./apps/mobile eas:build:production",
    "apk:staging": "pnpm --filter ./apps/mobile apk:staging",
    "apk:production": "pnpm --filter ./apps/mobile apk:production",
    "firebase:functions:typecheck": "pnpm --filter fresherflow-firebase-functions typecheck",
    "firebase:functions:deploy": "pnpm --filter fresherflow-firebase-functions deploy",
    "android:mobile:offline": "pnpm --filter ./apps/mobile android:offline",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=fresherflow-api",
    "build:web": "turbo run build --filter=fresherflow-web",
    "build:mobile": "turbo run build --filter=mobile",
    "deploy:web": "pnpm build:web",
    "deploy:api": "turbo run db:generate --filter=fresherflow-api && pnpm --filter ./apps/api prisma:migrate && turbo run build --filter=fresherflow-api",
    "deploy:worker": "turbo run build --filter=fresherflow-worker",
    "start:api": "pnpm --filter ./apps/api start",
    "start:worker": "pnpm --filter ./apps/api start:worker",
    "start:web": "pnpm --filter ./apps/web start",
    "db:generate": "pnpm --filter ./apps/api db:generate",
    "db:push": "pnpm --filter ./apps/api db:push",
    "db:studio": "pnpm --filter ./apps/api db:studio",
    "lint": "turbo run lint",
    "mobile": "pnpm --filter ./apps/mobile start:dev",
    "admin": "pnpm --filter ./apps/admin-mobile start:dev",
    "lint:api": "turbo run lint --filter=fresherflow-api",
    "lint:web": "turbo run lint --filter=fresherflow-web",
    "lint:mobile": "turbo run lint --filter=mobile",
    "clean": "rimraf apps/*/node_modules apps/*/dist packages/*/node_modules packages/*/dist node_modules",
    "typecheck": "turbo run typecheck",
    "typecheck:mobile": "turbo run typecheck --filter=mobile",
    "test": "turbo run test",
    "test:parser": "tsx scripts/test-parser.ts",
    "tree": "node docs/update_tree.js",
    "android": "pnpm android:dev",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "country-state-city": "^3.2.1",
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "turbo": "^2.8.1"
  },
  "devDependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "react-refresh": "^0.14.2",
    "rimraf": "^5.0.5",
    "turbo": "^2.8.1",
    "typescript": "^5.7.3",
    "ws": "^8.18.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": "22.x"
  },
  "keywords": [
    "monorepo",
    "jobs",
    "walk-ins",
    "opportunities"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "tar": "^7.5.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-dom": "19.1.0"
  }
}
