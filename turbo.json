{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalDependencies": [
        "package-lock.json",
        "turbo.json"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "build/**",
                "public/sitemap*.xml",
                "public/robots.txt"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "test": {
            "dependsOn": [
                "^build",
                "db:generate"
            ]
        },
        "db:generate": {
            "outputs": [
                "node_modules/.prisma/**"
            ]
        },
        "db:push": {
            "cache": false
        }
    }
}