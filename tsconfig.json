{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": "."
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/out"
  ],
  "extends": "expo/tsconfig.base"
}
